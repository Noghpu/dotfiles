[include]
    path = ~/.config/git/catppuccin.gitconfig

[core]
{{- if eq .chezmoi.os "windows" }}
    autocrlf = true
{{- else }}
    autocrlf = input
{{- end }}

{{ if lookPath "delta" -}}
pager = delta

[interactive]
    diffFilter = delta --color-only

[delta]
    features = catppuccin-mocha
    dark = true
    side-by-side = true
    line-numbers = true
    features = catppuccin-mocha

{{ end -}}
[merge]
    conflictstyle = zdiff3

[pull]
    rebase = true

[init]
    defaultBranch = main

[credential]
    helper = manager

[diff]
	algorithm = histogram
